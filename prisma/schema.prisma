generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String             @id @default(cuid())
  email                String             @unique
  name                 String?
  image                String?
  passwordHash         String?
  role                 UserRole           @default(FREELANCER)
  isVerified           Boolean            @default(false)
  isSuspended          Boolean            @default(false)
  suspendReason        String?
  lastLoginAt          DateTime?
  verificationToken    String?
  verificationExpiry   DateTime?
  isEmailVerified      Boolean            @default(false)
  stripeConnectId      String?            @unique
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  
  sessions             Session[]
  accounts             Account[]

  clientProfile        ClientProfile?
  clientContracts      Contract[]         @relation("ContractClient")
  freelancerContracts  Contract[]         @relation("ContractFreelancer")
  conversationsAsP1    Conversation[]     @relation("ConvParticipant1")
  conversationsAsP2    Conversation[]     @relation("ConvParticipant2")
  fraudAlerts          FraudAlert[]
  freelancerProfile    FreelancerProfile?
  jobsPosted           Job[]              @relation("JobClient")
  sentMessages         Message[]          @relation("MessageSender")
  notifications        Notification[]
  proposals            Proposal[]         @relation("ProposalFreelancer")
  reportsReceived      Report[]           @relation("ReportReported")
  reportsFiled         Report[]           @relation("ReportReporter")
  resolvedReports      Report[]           @relation("ReportResolver")
  reviewsReceived      Review[]           @relation("ReviewReviewee")
  reviewsGiven         Review[]           @relation("ReviewReviewer")
  savedJobs            SavedJob[]
  transactionsSent     Transaction[]      @relation("TxFromUser")
  transactionsReceived Transaction[]      @relation("TxToUser")

  @@index([role])
  @@index([isVerified])
  @@index([isSuspended])
  @@index([verificationToken])
}

model FreelancerProfile {
  id                 String             @id @default(cuid())
  userId             String             @unique
  displayName        String             @unique
  avatar             String?
  title              String?
  bio                String?
  skills             String             @default("")
  category           JobCategory        @default(OTHER)
  hourlyRate         Float?
  experienceLevel    ExperienceLevel    @default(BEGINNER)
  isStudent          Boolean            @default(false)
  studentInstitution String?
  studentMajor       String?
  expectedGraduation String?
  studentIdVerified  Boolean            @default(false)
  portfolio          String             @default("[]")
  availabilityStatus AvailabilityStatus @default(AVAILABLE)
  completedJobs      Int                @default(0)
  rating             Float              @default(0)
  totalReviews       Int                @default(0)
  location           String?
  timezone           String?
  englishLevel       EnglishLevel       @default(CONVERSATIONAL)
  socialLinks        String             @default("{}")
  isFeatured         Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([category])
  @@index([experienceLevel])
  @@index([availabilityStatus])
  @@index([hourlyRate])
  @@index([rating])
  @@index([isFeatured])
  @@index([isStudent])
}

model ClientProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  displayName     String   @unique
  companyName     String?
  companyLogo     String?
  companyWebsite  String?
  companySize     String?
  bio             String?
  industry        String?
  location        String?
  totalSpent      Float    @default(0)
  activeContracts Int      @default(0)
  jobsPosted      Int      @default(0)
  rating          Float    @default(0)
  totalReviews    Int      @default(0)
  isVerified      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([isVerified])
  @@index([industry])
  @@index([location])
}

model Job {
  id              String           @id @default(cuid())
  clientId        String
  title           String
  description     String
  category        JobCategory      @default(OTHER)
  budgetType      BudgetType       @default(FIXED_PRICE)
  budgetMin       Float?
  budgetMax       Float?
  duration        ProjectDuration?
  experienceLevel ExperienceLevel  @default(BEGINNER)
  skills          String           @default("")
  status          String           @default("DRAFT")
  proposalsCount  Int              @default(0)
  isUrgent        Boolean          @default(false)
  attachments     String           @default("[]")
  viewCount       Int              @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  contract        Contract?
  client          User             @relation("JobClient", fields: [clientId], references: [id], onDelete: Cascade)
  proposals       Proposal[]
  savedByUsers    SavedJob[]

  @@index([clientId])
  @@index([category])
  @@index([budgetType])
  @@index([experienceLevel])
  @@index([status])
  @@index([isUrgent])
  @@index([createdAt])
  @@index([budgetMin])
  @@index([budgetMax])
}

model Proposal {
  id               String         @id @default(cuid())
  jobId            String
  freelancerId     String
  coverLetter      String
  proposedAmount   Float
  proposedDuration String?
  status           ProposalStatus @default(PENDING)
  attachments      String         @default("[]")
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  contract         Contract?
  freelancer       User           @relation("ProposalFreelancer", fields: [freelancerId], references: [id], onDelete: Cascade)
  job              Job            @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, freelancerId])
  @@index([jobId])
  @@index([freelancerId])
  @@index([status])
  @@index([createdAt])
}

model Contract {
  id                   String         @id @default(cuid())
  jobId                String         @unique
  clientId             String
  freelancerId         String
  proposalId           String?        @unique
  title                String
  description          String?
  contractType         BudgetType     @default(FIXED_PRICE)
  totalAmount          Float          @default(0)
  hourlyRate           Float?
  estimatedHours       Int?
  status               ContractStatus @default(ACTIVE)
  startDate            DateTime?
  endDate              DateTime?
  clientApprovedAt     DateTime?
  freelancerApprovedAt DateTime?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  client               User           @relation("ContractClient", fields: [clientId], references: [id])
  freelancer           User           @relation("ContractFreelancer", fields: [freelancerId], references: [id])
  job                  Job            @relation(fields: [jobId], references: [id], onDelete: Cascade)
  proposal             Proposal?      @relation(fields: [proposalId], references: [id])
  conversations        Conversation[]
  milestones           Milestone[]
  reviews              Review[]
  transactions         Transaction[]

  @@index([clientId])
  @@index([freelancerId])
  @@index([status])
  @@index([contractType])
  @@index([startDate])
  @@index([proposalId])
}

model Milestone {
  id              String          @id @default(cuid())
  contractId      String
  title           String
  description     String?
  amount          Float           @default(0)
  dueDate         DateTime?
  status          MilestoneStatus @default(PENDING)
  submissionNotes String?
  approvalNotes   String?
  submittedAt     DateTime?
  approvedAt      DateTime?
  orderIndex      Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  contract        Contract        @relation(fields: [contractId], references: [id], onDelete: Cascade)
  transactions    Transaction[]

  @@index([contractId])
  @@index([status])
  @@index([orderIndex])
}

model Conversation {
  id             String    @id @default(cuid())
  participant1Id String
  participant2Id String
  contractId     String?
  lastMessageAt  DateTime  @default(now())
  isArchived     Boolean   @default(false)
  createdAt      DateTime  @default(now())
  contract       Contract? @relation(fields: [contractId], references: [id])
  participant1   User      @relation("ConvParticipant1", fields: [participant1Id], references: [id])
  participant2   User      @relation("ConvParticipant2", fields: [participant2Id], references: [id])
  messages       Message[]

  @@index([participant1Id])
  @@index([participant2Id])
  @@index([contractId])
  @@index([lastMessageAt])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  messageType    MessageType  @default(TEXT)
  fileUrl        String?
  fileName       String?
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("MessageSender", fields: [senderId], references: [id])

  @@index([conversationId])
  @@index([senderId])
  @@index([isRead])
  @@index([createdAt])
}

model Review {
  id              String   @id @default(cuid())
  contractId      String
  reviewerId      String
  revieweeId      String
  rating          Float
  quality         Float
  communication   Float
  professionalism Float
  comment         String?
  isPublic        Boolean  @default(true)
  createdAt       DateTime @default(now())
  contract        Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  reviewee        User     @relation("ReviewReviewee", fields: [revieweeId], references: [id])
  reviewer        User     @relation("ReviewReviewer", fields: [reviewerId], references: [id])

  @@unique([contractId, reviewerId])
  @@index([contractId])
  @@index([reviewerId])
  @@index([revieweeId])
  @@index([rating])
}

model Report {
  id                String             @id @default(cuid())
  reporterId        String
  reportedUserId    String
  reportType        ReportType
  description       String
  evidence          String             @default("{}")
  status            ReportStatus       @default(PENDING)
  adminNote         String?
  resolvedBy        String?
  relatedEntityType RelatedEntityType?
  relatedEntityId   String?
  createdAt         DateTime           @default(now())
  resolvedAt        DateTime?
  reportedUser      User               @relation("ReportReported", fields: [reportedUserId], references: [id])
  reporter          User               @relation("ReportReporter", fields: [reporterId], references: [id])
  resolvedByUser    User?              @relation("ReportResolver", fields: [resolvedBy], references: [id])

  @@index([reporterId])
  @@index([reportedUserId])
  @@index([reportType])
  @@index([status])
  @@index([resolvedBy])
  @@index([relatedEntityType])
  @@index([relatedEntityId])
}

model Transaction {
  id          String            @id @default(cuid())
  contractId  String?
  milestoneId String?
  fromUserId  String
  toUserId    String
  amount      Float
  platformFee Float             @default(0)
  netAmount   Float
  type        TransactionType
  status      TransactionStatus @default(PENDING)
  description String?
  createdAt   DateTime          @default(now())
  contract    Contract?         @relation(fields: [contractId], references: [id])
  fromUser    User              @relation("TxFromUser", fields: [fromUserId], references: [id])
  milestone   Milestone?        @relation(fields: [milestoneId], references: [id])
  toUser      User              @relation("TxToUser", fields: [toUserId], references: [id])

  @@index([contractId])
  @@index([milestoneId])
  @@index([fromUserId])
  @@index([toUserId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
}

model Notification {
  id                String             @id @default(cuid())
  userId            String
  type              NotificationType
  title             String
  message           String
  isRead            Boolean            @default(false)
  actionUrl         String?
  relatedEntityType RelatedEntityType?
  relatedEntityId   String?
  createdAt         DateTime           @default(now())
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([isRead])
  @@index([createdAt])
}

model SavedJob {
  id        String   @id @default(cuid())
  userId    String
  jobId     String
  createdAt DateTime @default(now())
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([userId])
  @@index([jobId])
}

model Skill {
  id        String      @id @default(cuid())
  name      String      @unique
  category  JobCategory @default(OTHER)
  icon      String?
  createdAt DateTime    @default(now())

  @@index([category])
  @@index([name])
}

model FraudAlert {
  id          String    @id @default(cuid())
  userId      String
  alertType   String
  severity    String    @default("MEDIUM")
  description String
  metadata    String    @default("{}")
  status      String    @default("PENDING")
  reviewedBy  String?
  reviewedAt  DateTime?
  adminNote   String?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([alertType])
  @@index([severity])
  @@index([status])
  @@index([createdAt])
}

enum UserRole {
  CLIENT
  FREELANCER
  ADMIN
}

enum JobCategory {
  DESIGNER
  WEB_DEVELOPER
  MOBILE_DEVELOPER
  VIDEO_EDITOR
  CONTENT_CREATOR
  MARKETING
  WRITING
  TRANSLATION
  DATA_SCIENCE
  ADMIN_SUPPORT
  OTHER
}

enum BudgetType {
  FIXED_PRICE
  HOURLY
}

enum ProjectDuration {
  LESS_THAN_1_WEEK
  ONE_TO_4_WEEKS
  ONE_TO_3_MONTHS
  THREE_TO_6_MONTHS
  MORE_THAN_6_MONTHS
}

enum ExperienceLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum EnglishLevel {
  BASIC
  CONVERSATIONAL
  FLUENT
  NATIVE
}

enum ProposalStatus {
  PENDING
  SHORTLISTED
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum ContractStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
  DISPUTED
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  SUBMITTED
  REQUESTED_APPROVAL
  APPROVED
  REJECTED
  PAID
}

enum MessageType {
  TEXT
  FILE
  SYSTEM
}

enum ReportType {
  SCAM
  HARASSMENT
  SPAM
  INAPPROPRIATE_CONTENT
  PAYMENT_DISPUTE
  OTHER
}

enum ReportStatus {
  PENDING
  UNDER_REVIEW
  RESOLVED
  DISMISSED
}

enum TransactionType {
  ESCROW_DEPOSIT
  PAYMENT_RELEASE
  REFUND
  PLATFORM_FEE
  WITHDRAWAL
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum NotificationType {
  NEW_PROPOSAL
  PROPOSAL_ACCEPTED
  PROPOSAL_REJECTED
  NEW_MESSAGE
  MILESTONE_APPROVED
  PAYMENT_RECEIVED
  CONTRACT_COMPLETED
  NEW_REVIEW
  REPORT_STATUS
  SYSTEM
}

enum AvailabilityStatus {
  AVAILABLE
  PARTIALLY_AVAILABLE
  NOT_AVAILABLE
}

enum RelatedEntityType {
  USER
  JOB
  PROPOSAL
  CONTRACT
  MESSAGE
}
model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}
